import tkinter as tk
from tkinter import ttk, messagebox
from deep_translator import GoogleTranslator

# Initialize the main window
root = tk.Tk()
root.title("Language Translation Tool")
root.geometry("550x400")
root.resizable(False, False)
root.configure(bg="#f0f2f5")

# Supported languages dictionary (Layout: "Display Name": "Code")
LANGUAGES = {
    "English": "en",
    "Spanish": "es",
    "French": "fr",
    "German": "de",
    "Italian": "it",
    "Chinese (Simplified)": "zh-CN",
    "Japanese": "ja",
    "Korean": "ko",
    "Hindi": "hi",
    "Arabic": "ar",
    "Tamil":"ta"
}

# --- Translation Logic ---
def translate_text():
    source_text = text_input.get("1.0", tk.END).strip()
    target_lang_name = lang_box.get()
   
    if not source_text:
        messagebox.showwarning("Warning", "Please enter some text to translate.")
        return
       
    target_code = LANGUAGES.get(target_lang_name)
   
    try:
        # GoogleTranslator will automatically detect the source language
        translated = GoogleTranslator(source='auto', target=target_code).translate(source_text)
       
        # Clear output box and insert the new translation
        text_output.config(state=tk.NORMAL)
        text_output.delete("1.0", tk.END)
        text_output.insert(tk.END, translated)
        text_output.config(state=tk.DISABLED) # Make it read-only again
    except Exception as e:
        messagebox.showerror("Error", f"Translation failed: {e}")

# --- UI Layout ---

# Title Label
title_label = tk.Label(root, text="Language Translator", font=("Helvetica", 16, "bold"), bg="#f0f2f5", fg="#333333")
title_label.pack(pady=10)

# Input Text Frame
input_frame = tk.LabelFrame(root, text="Enter Text (Auto-detects language)", font=("Helvetica", 10, "bold"), bg="#f0f2f5")
input_frame.pack(padx=20, fill="both", expand=True)

text_input = tk.Text(input_frame, height=5, wrap=tk.WORD, font=("Helvetica", 11))
text_input.pack(padx=10, pady=5, fill="both", expand=True)

# Control Frame (Dropdown and Button)
control_frame = tk.Frame(root, bg="#f0f2f5")
control_frame.pack(pady=10)

lang_label = tk.Label(control_frame, text="Translate to:", font=("Helvetica", 10), bg="#f0f2f5")
lang_label.pack(side=tk.LEFT, padx=5)

# Dropdown Menu for Languages
lang_box = ttk.Combobox(control_frame, values=list(LANGUAGES.keys()), state="readonly", width=18)
lang_box.set("Spanish") # Default value
lang_box.pack(side=tk.LEFT, padx=5)

# Translate Button
translate_btn = tk.Button(control_frame, text="Translate", command=translate_text, bg="#007bff", fg="white", font=("Helvetica", 10, "bold"), relief="flat", padx=10)
translate_btn.pack(side=tk.LEFT, padx=10)

# Output Text Frame
output_frame = tk.LabelFrame(root, text="Translation", font=("Helvetica", 10, "bold"), bg="#f0f2f5")
output_frame.pack(padx=20, pady=(0, 20), fill="both", expand=True)

text_output = tk.Text(output_frame, height=5, wrap=tk.WORD, font=("Helvetica", 11), state=tk.DISABLED, bg="#e9ecef")
text_output.pack(padx=10, pady=5, fill="both", expand=True)
def copy_text():
    root.clipboard_clear()
    root.clipboard_append(text_output.get("1.0", END))
# Start the application loop
root.mainloop()
